<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="StarSorter.Views.AIClassifyContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:StarSorter.ViewModels"
    mc:Ignorable="d">

    <Grid MinWidth="500" MinHeight="350">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <Button
                x:Name="ExportButton"
                Click="ExportButton_Click"
                Style="{ThemeResource AccentButtonStyle}"
                Content="导出数据" />
            <Button
                x:Name="ImportButton"
                Click="ImportButton_Click"
                Style="{ThemeResource DefaultButtonStyle}"
                Content="导入结果" />
        </StackPanel>

        <TextBlock
            Grid.Row="1"
            x:Name="StatusText"
            Margin="0,0,0,8"
            Opacity="0.7"
            Style="{ThemeResource BodyTextBlockStyle}"
            Text="..." />

        <Grid Grid.Row="2" x:Name="PreviewPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView
                x:Name="CategoryListView"
                Grid.Column="0"
                Margin="0,0,8,0"
                ItemsSource="{x:Bind PreviewCategories, Mode=OneWay}"
                SelectionMode="Single"
                SelectionChanged="CategoryListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:PreviewCategory">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" />
                            <TextBlock
                                Opacity="0.5"
                                Text="{x:Bind RepoCount}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListView
                x:Name="RepoListView"
                Grid.Column="1"
                ItemsSource="{x:Bind CurrentCategoryRepos, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <TextBlock
            Grid.Row="3"
            x:Name="SummaryText"
            Margin="0,8,0,0"
            Opacity="0.6"
            Style="{ThemeResource CaptionTextBlockStyle}" />
    </Grid>
</UserControl>
