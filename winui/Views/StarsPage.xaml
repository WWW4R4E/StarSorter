<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StarSorter.Views.StarsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:StarSorter.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:StarSorter.Helpers"
    xmlns:local="using:StarSorter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:StarSorter.ViewModels"
    NavigationCacheMode="Enabled"
    RightTapped="Page_RightTapped"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="NavLinkItemTemplate" x:DataType="viewModels:NavLink">
            <StackPanel
                Padding="12,8"
                Orientation="Horizontal"
                Spacing="12">
                <FontIcon FontSize="14" Glyph="{x:Bind Glyph}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="{x:Bind Label}" />
            </StackPanel>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="TopicsPanelTemplate">
            <WrapGrid MaximumRowsOrColumns="5" Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="StarRepositoryTemplate" x:DataType="viewModels:StarRepository">
            <Border
                Width="300"
                Margin="4"
                Padding="12"
                HorizontalAlignment="Right"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="36" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border
                            Grid.RowSpan="2"
                            Width="40"
                            Height="40"
                            Margin="0,0,10,0"
                            VerticalAlignment="Top">
                            <controls:CachedImageControl
                                Width="40"
                                Height="40"
                                Source="{x:Bind ImageUrl}" />
                        </Border>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            FontWeight="SemiBold"
                            Style="{ThemeResource BaseTextBlockStyle}"
                            Text="{x:Bind Name}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,2,0,0"
                            VerticalAlignment="Top"
                            MaxLines="2"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind Description}"
                            TextWrapping="NoWrap" />
                    </Grid>

                    <StackPanel
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="8">
                        <FontIcon FontSize="12" Glyph="&#xE734;" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.8"
                            Text="{x:Bind Stars}" />
                        <FontIcon
                            Margin="12,0,0,0"
                            FontSize="12"
                            Glyph="&#xE7B3;" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.8"
                            Text="{x:Bind Forks}" />
                    </StackPanel>

                    <local:TopicsRepeater
                        Grid.Row="2"
                        MinHeight="16"
                        Topics="{x:Bind Topics}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!--  Loading State  -->
        <Grid Visibility="{x:Bind local:StarsPage.ToVisibility(ViewModel.IsLoading), Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <ProgressRing
                    Width="48"
                    Height="48"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.6"
                    Text="{x:Bind ViewModel.GetLocalizedString('LoadingStars'), Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!--  Error State  -->
        <Grid Visibility="{x:Bind local:StarsPage.ToVisibility(ViewModel.HasError), Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="48"
                    Glyph="&#xE783;"
                    Opacity="0.6" />
                <TextBlock
                    MaxWidth="400"
                    HorizontalAlignment="Center"
                    Opacity="0.6"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <Button
                    HorizontalAlignment="Center"
                    Content="{x:Bind ViewModel.GetLocalizedString('Retry'), Mode=OneWay}"
                    Click="RetryButton_Click" />
            </StackPanel>
        </Grid>

        <!--  Content (visible when not loading and no error)  -->
        <SplitView
            x:Name="splitView"
            Visibility="{x:Bind local:StarsPage.ToVisibility(ViewModel.IsContentVisible), Mode=OneWay}"
            CompactPaneLength="48"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="256"
            PaneBackground="{ThemeResource LayerFillColorDefaultBrush}"
            PanePlacement="Right">
            <SplitView.Pane>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListView
                        x:Name="CategoryNavLinksList"
                        Grid.Row="1"
                        Margin="0,12,0,0"
                        VerticalAlignment="Stretch"
                        IsItemClickEnabled="True"
                        ItemClick="CategoryNavLinksList_ItemClick"
                        ItemTemplate="{StaticResource NavLinkItemTemplate}"
                        ItemsSource="{x:Bind ViewModel.NavLinks}"
                        SelectedIndex="0"
                        SelectionMode="Single"
                        RightTapped="CategoryNavLinksList_RightTapped" />
                    <StackPanel
                        Grid.Row="2"
                        Margin="8"
                        Orientation="Vertical"
                        Spacing="8">
                        <Button
                            x:Name="AddCategoryButton"
                            Click="AddCategoryButton_Click"
                            HorizontalAlignment="Stretch"
                            Style="{ThemeResource AccentButtonStyle}"
                            Content="新建"/>
                        <Button
                            x:Name="MultiSelectButton"
                            Click="MultiSelectButton_Click"
                            HorizontalAlignment="Stretch"
                            Style="{ThemeResource DefaultButtonStyle}"
                            Content="多选"/>
                        <Button
                            x:Name="SmartClassifyButton"
                            Click="SmartClassifyButton_Click"
                            HorizontalAlignment="Stretch"
                            Style="{ThemeResource DefaultButtonStyle}"
                            Content="智能分类"/>

                    </StackPanel>
                </Grid>
            </SplitView.Pane>
            <SplitView.Content>
                <Grid>
                    <GridView
                        x:Name="StarsGridView"
                        Margin="0,24,0,0"
                        Padding="16,0"
                        HorizontalAlignment="Center"
                        IsItemClickEnabled="True"
                        ItemClick="StarsGridView_ItemClick"
                        ItemTemplate="{StaticResource StarRepositoryTemplate}"
                        ItemsSource="{x:Bind ViewModel.CurrentCategoryStars, Mode=OneWay}"
                        RightTapped="StarsGridView_RightTapped"
                        SelectionMode="None" />
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>