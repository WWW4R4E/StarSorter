<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="StarSorter.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:StarSorter.ViewModels"
    xmlns:local="using:StarSorter.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:StarSorter.Helpers"
    xmlns:controls="using:StarSorter.Controls"
    xmlns:data="using:Windows.UI.Xaml.Data"
    mc:Ignorable="d">

    <Grid>
        <!-- Loading State -->
        <Grid Visibility="{x:Bind local:ProfilePage.ToVisibility(ViewModel.IsLoading), Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <ProgressRing
                    Width="48"
                    Height="48"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.6"
                    Text="{x:Bind ViewModel.GetLocalizedString('LoadingStars'), Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Error State -->
        <Grid Visibility="{x:Bind local:ProfilePage.ToVisibility(ViewModel.HasError), Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="48"
                    Glyph="&#xE783;"
                    Opacity="0.6" />
                <TextBlock
                    MaxWidth="400"
                    HorizontalAlignment="Center"
                    Opacity="0.6"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <Button
                    HorizontalAlignment="Center"
                    Content="{x:Bind ViewModel.GetLocalizedString('Retry'), Mode=OneWay}"
                    Click="RetryButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Margin="0,8,16,0" Visibility="{x:Bind local:ProfilePage.ToVisibility(ViewModel.IsContentVisible), Mode=OneWay}">
        <ScrollViewer Margin="24,24,12,0">
            <Grid RowSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="24">
                    <Border>
                        <StackPanel Spacing="16" HorizontalAlignment="Left">
                            <Border>
                                <controls:CachedImageControl
                                    Source="{x:Bind ViewModel.User.AvatarUrl, Mode=OneWay}"/>
                            </Border>

                            <TextBlock
                                Text="{x:Bind ViewModel.User.Name, Mode=OneWay}"
                                Style="{ThemeResource TitleTextBlockStyle}"
                                HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.NameVisibility, Mode=OneWay}" />

                            <TextBlock
                                Text="{x:Bind ViewModel.User.Login, Mode=OneWay}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.NameVisibility, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <TextBlock
                                Text="{x:Bind ViewModel.User.Login, Mode=OneWay}"
                                Style="{ThemeResource TitleTextBlockStyle}"
                                HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.LoginOnlyVisibility, Mode=OneWay}" />

                            <TextBlock
                                Text="{x:Bind ViewModel.User.Bio, Mode=OneWay}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                Visibility="{x:Bind ViewModel.BioVisibility, Mode=OneWay}" />

                            <HyperlinkButton
                                Content="{x:Bind ViewModel.User.Blog, Mode=OneWay}"
                                NavigateUri="{x:Bind ViewModel.User.BlogUri, Mode=OneWay}"
                                HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.BlogVisibility, Mode=OneWay}" />

                            <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.3" />

                            <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.DetailsVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.CompanyVisibility, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE7ED;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.User.Company, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.LocationVisibility, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE707;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.User.Location, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.EmailVisibility, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE715;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <HyperlinkButton Content="{x:Bind ViewModel.User.Email, Mode=OneWay}" NavigateUri="{x:Bind ViewModel.User.EmailUri, Mode=OneWay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.TwitterVisibility, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE212;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.User.TwitterUsername, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>


                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0">
                        <StackPanel Spacing="16">
                            <Grid RowSpacing="16" ColumnSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border  Grid.Row="0" Grid.Column="0" Padding="16" Style="{ThemeResource CardBorderStyle}">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind ViewModel.User.PublicRepos, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind ViewModel.GetLocalizedString('ProfileRepositories'), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" Padding="16" Style="{ThemeResource CardBorderStyle}">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind ViewModel.User.Followers, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind ViewModel.GetLocalizedString('ProfileFollowers'), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Padding="16" Style="{ThemeResource CardBorderStyle}">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind ViewModel.User.Following, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind ViewModel.GetLocalizedString('ProfileFollowing'), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="3" Padding="16" Style="{ThemeResource CardBorderStyle}">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind ViewModel.User.PublicGists, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind ViewModel.GetLocalizedString('ProfileGists'), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="2">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{x:Bind ViewModel.GetLocalizedString('ProfileApiRateLimit'), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,16"/>

                            <Grid Padding="12" Background="{ThemeResource SystemControlBackgroundListLowBrush}" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE74C;"  VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.GetLocalizedString('ProfileCoreApi'), Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.LabelCoreApiDescription, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.RateLimitCore, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                            </Grid>

                            <Grid Padding="12" Background="{ThemeResource SystemControlBackgroundListLowBrush}" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE721;"  VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.GetLocalizedString('ProfileSearchApi'), Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.LabelSearchApiDescription, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.RateLimitSearch, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
        </Grid>
    </Grid>
</Page>