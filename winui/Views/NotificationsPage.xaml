<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StarSorter.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:StarSorter.Helpers"
    xmlns:controls="using:StarSorter.Controls"
    xmlns:local="using:StarSorter.Views"
    xmlns:models="using:StarSorter.Models"
    xmlns:viewModels="using:StarSorter.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="NavLinkItemTemplate" x:DataType="viewModels:NavLink">
            <StackPanel
                Padding="12,8"
                Orientation="Horizontal"
                Spacing="12">
                <FontIcon FontSize="14" Glyph="{x:Bind Glyph}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="{x:Bind Label}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="IssueCardTemplate" x:DataType="models:NotificationThread">
            <controls:IssueNotificationCard Margin="4" />
        </DataTemplate>

        <DataTemplate x:Key="PullRequestCardTemplate" x:DataType="models:NotificationThread">
            <controls:PullRequestCard Margin="4" />
        </DataTemplate>

        <DataTemplate x:Key="ReleaseCardTemplate" x:DataType="models:NotificationThread">
            <controls:ReleaseCard Margin="4" />
        </DataTemplate>

        <DataTemplate x:Key="CommitCardTemplate" x:DataType="models:NotificationThread">
            <controls:CommitCard Margin="4" />
        </DataTemplate>

        <controls:NotificationCardSelector x:Key="NotificationCardSelector"
            IssueTemplate="{StaticResource IssueCardTemplate}"
            PullRequestTemplate="{StaticResource PullRequestCardTemplate}"
            ReleaseTemplate="{StaticResource ReleaseCardTemplate}"
            CommitTemplate="{StaticResource CommitCardTemplate}"
            DefaultTemplate="{StaticResource IssueCardTemplate}" />

        <DataTemplate x:Key="NotificationWrapperTemplate" x:DataType="models:NotificationThread">
            <ContentControl
                Content="{Binding}"
                ContentTemplateSelector="{StaticResource NotificationCardSelector}"
                HorizontalContentAlignment="Stretch"
                HorizontalAlignment="Stretch" />
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- Loading State -->
        <Grid Visibility="{x:Bind local:NotificationsPage.ToVisibility(ViewModel.IsLoading), Mode=OneWay}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <ProgressRing
                    Width="48"
                    Height="48"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.6"
                    Text="{x:Bind ViewModel.GetLocalizedString('LoadingStars'), Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <SplitView
            x:Name="splitView"
            Visibility="{x:Bind local:NotificationsPage.ToInvertedVisibility(ViewModel.IsLoading), Mode=OneWay}"
            CompactPaneLength="48"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="256"
            PaneBackground="{ThemeResource LayerFillColorDefaultBrush}"
            PanePlacement="Right">
            <SplitView.Pane>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="16,24,0,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.GetLocalizedString('NotificationCategory'), Mode=OneWay}" />
                    <ListView
                        x:Name="NotificationsNavLinksList"
                        Grid.Row="1"
                        VerticalAlignment="Stretch"
                        IsItemClickEnabled="True"
                        ItemClick="NotificationsNavLinksList_ItemClick"
                        SelectedIndex="0"
                        ItemTemplate="{StaticResource NavLinkItemTemplate}"
                        ItemsSource="{x:Bind ViewModel.NavLinks}"
                        SelectionMode="Single" />
                    <Button
                        Grid.Row="2"
                        Margin="12,8,12,16"
                        HorizontalAlignment="Stretch"
                        Content="{x:Bind ViewModel.GetLocalizedString('MarkAllRead'), Mode=OneWay}"
                        Click="MarkAllReadButton_Click" />
                </Grid>
            </SplitView.Pane>
            <Grid Margin="24,24,24,16">
                <ListView
                    x:Name="NotificationsListView"
                    ItemsSource="{x:Bind ViewModel.CurrentCategoryNotifications, Mode=OneWay}"
                    ItemTemplateSelector="{StaticResource NotificationCardSelector}"
                    SelectionMode="None"
                    IsItemClickEnabled="True"
                    ItemClick="NotificationsListView_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </SplitView>
    </Grid>
</Page>
