<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="StarSorter.Controls.PullRequestCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:StarSorter.Controls"
    xmlns:models="using:StarSorter.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DataType="models:NotificationThread">

    <Border
        x:Name="CardBorder"
        Margin="4"
        Padding="16"
        Style="{ThemeResource CardBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左侧内容区 -->
            <RelativePanel Grid.Column="0">
                <controls:CachedImageControl
                    x:Name="RepoAvatar"
                    Width="32"
                    Height="32"
                    Source="{x:Bind ViewModel.Repository.Owner.AvatarUrl, Mode=OneWay}" />

                <TextBlock
                    x:Name="RepoName"
                    RelativePanel.RightOf="RepoAvatar"
                    RelativePanel.AlignVerticalCenterWith="RepoAvatar"
                    Margin="8,0,0,0"
                    Text="{x:Bind ViewModel.Repository.FullName, Mode=OneWay}"
                    TextWrapping="NoWrap"
                    TextTrimming="CharacterEllipsis" />

                <TextBlock
                    x:Name="TimeText"
                    RelativePanel.RightOf="RepoName"
                    RelativePanel.AlignVerticalCenterWith="RepoAvatar"
                    Margin="8,0,0,0"
                    Text="{x:Bind ViewModel.TimeAgo, Mode=OneWay}"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                <TextBlock
                    x:Name="PrTitle"
                    RelativePanel.Below="RepoAvatar"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.Subject.Title, Mode=OneWay}"
                    TextWrapping="Wrap"
                    MaxLines="2"
                    TextTrimming="CharacterEllipsis" />
            </RelativePanel>

            <!-- 右侧内容区 -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="TypeBadge" Padding="6,2" Background="{ThemeResource SystemAccentColor}">
                        <TextBlock Text="Pull Request" Foreground="White" />
                    </Border>

                    <Border
                        x:Name="ReasonBadge"
                        Margin="6,0,0,0"
                        Padding="6,2"
                        Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                        <TextBlock Text="{x:Bind ViewModel.ReasonLabel, Mode=OneWay}" />
                    </Border>
                </StackPanel>

                <Button
                    x:Name="DeleteButton"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Right"
                    Padding="4"
                    BorderThickness="0"
                    Click="DeleteButton_Click">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>